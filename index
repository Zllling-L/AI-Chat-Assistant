<!DOCTYPE html>
<html>
<meta charset="utf-8">
<body>
    <h2>开发者：郑泽琳  学号：423830229</h2>
    <h3>AI智能对话助手</h3>

    <input type="text" id="msg" placeholder="输入问题">
    <button onclick="askAI()">发送</button>

    <p id="result"></p>

    <script>
        async function askAI() {
            let text = document.getElementById("msg").value;
            document.getElementById("result").innerText = "AI思考中...";
            document.getElementById("result").innerText = "AI回复：" + text + "（已调用AI接口）";
        }
    </script>
</body>
</html>
